NODE_ENV=development
PORT=3005

# PostgreSQL connection for local development. Replace the password/port/database
# with your own local values. Do not commit real credentials in .env files.
DB_NAME=dgop_dev
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/dgop_dev?schema=public

# Use a long random value in every shared or production-like environment.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h
HEALTH_INCLUDE_DETAILS=false

# Local Angular dev server / public tunnel origin.
PUBLIC_ORIGIN=http://localhost:4205
CORS_ORIGINS=http://localhost:4205

# Seed accounts are for local demo data only. Override them before any shared demo.
SEED_ADMIN_EMAIL=admin@dgop.local
SEED_ADMIN_PASSWORD=replace-with-local-demo-password
SEED_PERSON_PASSWORD=replace-with-local-demo-password

# Evidence file storage. Use object storage or a secured mounted path for production.
EVIDENCE_STORAGE_DIR=storage/evidence
EVIDENCE_MAX_BYTES=15728640
