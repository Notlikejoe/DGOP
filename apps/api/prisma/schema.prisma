}

/// Mandatory or recommended training mapped to DGOP application roles.
model TrainingRequirement {
  id             String         @id @default(uuid())
  courseId       String
  roleId         String
  mandatory      Boolean        @default(true)
  dueDays        Int            @default(30)
  validityMonths Int?
  course         TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  role           Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([courseId, roleId])
  @@index([roleId])
  @@map("training_requirements")
}

/// A user's assigned/completed/expired training record.
model TrainingAssignment {
  id           String                   @id @default(uuid())
  courseId     String
  userId       String
  personId     String?
  status       TrainingAssignmentStatus @default(assigned)
  dueDate      DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?
  score        Int?
  evidenceNote String?
  assignedBy   String?
  source       String                   @default("manual")
  course       TrainingCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  person       Person?                  @relation(fields: [personId], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([userId, status])
  @@index([courseId, status])
  @@index([dueDate])
  @@index([expiresAt])
  @@map("training_assignments")
}

model CertificationTrack {
