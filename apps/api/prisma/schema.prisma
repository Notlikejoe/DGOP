// DGOP Prisma schema - Sprint 0 foundation.
// Lookups and audit scaffolding; domain entities are added in later sprints.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application roles (RBAC).
model Role {
  id                    String           @id @default(uuid())
  code                  String           @unique
  nameEn                String
  nameAr                String
  description           String?
  isSystem              Boolean          @default(false)
  isActive              Boolean          @default(true)
  deletedAt             DateTime?
  /// Max classification rank this role may view (null = unrestricted).
  maxClassificationRank Int?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  userRoles             UserRole[]
  permissions           RolePermission[]
  dataScopes            RoleDataScope[]
  dataAccessMappings    RoleDataAccessMap[]
  accessReviewItems     AccessReviewItem[]
  abacDecisions         AbacDecisionLog[]
  trainingRequirements  TrainingRequirement[]

  @@map("roles")
}

/// Catalog of granular permissions as resource + action pairs.
model Permission {
  id            String           @id @default(uuid())
  resource      String
  action        String
  descriptionEn String?
  descriptionAr String?
  createdAt     DateTime         @default(now())
  roles         RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

/// Many-to-many assignment of permissions to roles.
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum DataScopeType {
  org_unit
  data_domain
}

/// Per-role data visibility scope (org unit / data domain memberships).
model RoleDataScope {
  id                String        @id @default(uuid())
  roleId            String
  scopeType         DataScopeType
  refId             String
  includeDescendants Boolean      @default(true)
  role              Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, scopeType, refId])
  @@index([roleId])
  @@map("role_data_scopes")
}

/// Application users (local authentication for development).
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  displayName  String
  isActive     Boolean    @default(true)
  tokenVersion Int        @default(0) @map("token_version")
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userRoles    UserRole[]
  person       Person?
  workflowTasks WorkflowTask[]
  trainingAssignments TrainingAssignment[]
  certificationAttempts CertificationAttempt[]
  continuingEducationActivities ContinuingEducationActivity[]
  ownedAccessReviews AccessReview[] @relation("AccessReviewOwner")
  accessReviewItems AccessReviewItem[]
  abacDecisions AbacDecisionLog[]
  governanceNotifications GovernanceNotification[]

  @@map("users")
}

/// Many-to-many assignment of roles to users.
model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Directory of people (governance actors); optionally linked to a login account.
model Person {
  id           String                  @id @default(uuid())
  fullNameEn   String
  fullNameAr   String
  email        String?                 @unique
  jobTitle     String?
  organization String?
  userId       String?                 @unique
  user         User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  isActive     Boolean                 @default(true)
  deletedAt    DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  assignments  StewardshipAssignment[]
  rules        AssignmentRule[]
  ownedNdiSpecs NdiSpecification[]     @relation("NdiSpecOwner")
  trainingAssignments TrainingAssignment[]
  certificationAttempts CertificationAttempt[]
  continuingEducationActivities ContinuingEducationActivity[]
  communityArticles CommunityArticle[]
  expertProfile ExpertProfile?
  mentorshipsAsMentor MentorshipPair[] @relation("MentorPerson")
  mentorshipsAsMentee MentorshipPair[] @relation("MenteePerson")
  dataQualityIssues DataQualityIssue[]
  dataQualityRules DataQualityRule[]
  dlpIncidents DlpIncident[]
  openDataOwnerCandidates OpenDataCandidate[] @relation("OpenDataOwner")
  openDataStewardCandidates OpenDataCandidate[] @relation("OpenDataSteward")
  openDataReviewerCandidates OpenDataCandidate[] @relation("OpenDataReviewer")
  foiAssignedRequests FoiRequest[] @relation("FoiAssignedOfficer")
  foiReviews FoiReview[] @relation("FoiReviewer")
  foiAppeals FoiAppeal[] @relation("FoiAppealOfficer")
  privacyRopaRecords PrivacyRopaRecord[] @relation("PrivacyRopaOwner")
  privacyDpiaReviews PrivacyDpia[] @relation("PrivacyDpiaReviewer")
  privacyGateReviews PrivacyGate[] @relation("PrivacyGateReviewer")
  privacyDsrRequests PrivacyDsrRequest[] @relation("PrivacyDsrAssignee")
  privacyBreaches PrivacyBreach[] @relation("PrivacyBreachAssignee")
  privacyRetentionRules PrivacyRetentionRule[] @relation("PrivacyRetentionOwner")
  dataSharingReviews DataSharingReview[] @relation("DataSharingReviewer")
  dataSharingAgreements DataSharingAgreement[] @relation("DataSharingAgreementOwner")

  @@map("people")
}

/// Data classification levels (e.g. Public..Top Secret).
model Classification {
  id          String      @id @default(uuid())
  code        String      @unique
  nameEn      String
  nameAr      String
  rank        Int
  color       String
  description String?
  isActive    Boolean     @default(true)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  assets      DataAsset[]
  maskingPolicies MaskingPolicy[]
  dataAccessMappings RoleDataAccessMap[]
  accessReviewItems AccessReviewItem[]
  abacDecisions AbacDecisionLog[]
  dlpIncidents DlpIncident[]
  classificationRequestsFrom ClassificationChangeRequest[] @relation("ClassificationChangeFrom")
  classificationRequestsTo ClassificationChangeRequest[] @relation("ClassificationChangeTo")
  openDataCandidates OpenDataCandidate[]
  foiRequests FoiRequest[]
  foiExemptions FoiExemptionEvidence[]
  privacyDpiaRecords PrivacyDpia[]
  dataSharingRequests DataSharingRequest[]

  @@map("classifications")
}

/// Organizational hierarchy (entities, departments, sections).
model OrganizationUnit {
  id        String             @id @default(uuid())
  code      String             @unique
  nameEn    String
  nameAr    String
  parentId  String?
  parent    OrganizationUnit?  @relation("OrgTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrganizationUnit[] @relation("OrgTree")
  systems   SystemPlatform[]
  assets    DataAsset[]
  isActive  Boolean            @default(true)
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([parentId])
  @@map("organization_units")
}

/// Systems / platforms that host or process data assets.
model SystemPlatform {
  id             String            @id @default(uuid())
  code           String            @unique
  nameEn         String
  nameAr         String
  description    String?
  vendor         String?
  type           String?
  ownerOrgUnitId String?
  ownerOrgUnit   OrganizationUnit? @relation(fields: [ownerOrgUnitId], references: [id], onDelete: SetNull)
  assets         DataAsset[]
  isActive       Boolean           @default(true)
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("systems")
}

/// Governance role types (used by RACI templates and assignments).
model RoleType {
  id          String             @id @default(uuid())
  code        String             @unique
  nameEn      String
  nameAr      String
  description String?
  isActive    Boolean            @default(true)
  deletedAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  raciItems   RaciTemplateItem[]
  assignments StewardshipAssignment[]
  rules       AssignmentRule[]

  @@map("role_types")
}

enum RaciResponsibility {
  R
  A
  C
  I
}

/// RACI templates that can be applied to governance process types.
model RaciTemplate {
  id          String             @id @default(uuid())
  code        String             @unique
  nameEn      String
  nameAr      String
  description String?
  processType String?
  isActive    Boolean            @default(true)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       RaciTemplateItem[]

  @@map("raci_templates")
}

model RaciTemplateItem {
  id             String             @id @default(uuid())
  templateId     String
  roleTypeId     String
  responsibility RaciResponsibility
  template       RaciTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  roleType       RoleType           @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)

  @@unique([templateId, roleTypeId])
  @@map("raci_template_items")
}

/// Reusable status values grouped by domain (workflow, compliance, etc.).
model StatusValue {
  id        String    @id @default(uuid())
  domain    String
  code      String
  nameEn    String
  nameAr    String
  color     String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([domain, code])
  @@map("status_values")
}

/// National Data Index (NDI) governance domains.
model NdiDomain {
  id        String   @id @default(uuid())
  code      String   @unique
  /// Optional short abbreviation for charts/labels (e.g. DG, DQ, PDP). Display only.
  shortCode String?
  nameEn    String
  nameAr    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specifications NdiSpecification[]
  auditPacks     NdiAuditPack[]

  @@map("ndi_domains")
}

/// Business data domains (hierarchical taxonomy of data areas).
model DataDomain {
  id          String       @id @default(uuid())
  code        String       @unique
  nameEn      String
  nameAr      String
  description String?
  parentId    String?
  parent      DataDomain?  @relation("DomainTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    DataDomain[] @relation("DomainTree")
  assets      DataAsset[]
  dqRules     DataQualityRule[]
  dqScores    DataQualityScore[]
  dqProfiles  DataQualityProfile[]
  maskingPolicies MaskingPolicy[]
  dataAccessMappings RoleDataAccessMap[]
  accessReviewItems AccessReviewItem[]
  abacDecisions AbacDecisionLog[]
  workflowTemplates WorkflowTemplate[]
  foiRequests FoiRequest[]
  privacyRopaRecords PrivacyRopaRecord[]
  privacyDpiaRecords PrivacyDpia[]
  privacyDsrRequests PrivacyDsrRequest[]
  privacyBreaches PrivacyBreach[]
  privacyRetentionRules PrivacyRetentionRule[]
  dataSharingRequests DataSharingRequest[]
  dataSharingAgreements DataSharingAgreement[]
  referenceDataVersions ReferenceDataVersion[]
  businessGlossaryTerms BusinessGlossaryTerm[]
  businessLineageMaps BusinessLineageMap[]
  dataAssetValuations DataAssetValuation[]
  businessImpactAssessments BusinessImpactAssessment[]
  dataValueKpis DataValueKpi[]
  isActive    Boolean      @default(true)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([parentId])
  @@map("data_domains")
}

/// Type of an NDI specification entry.
enum NdiSpecType {
  policy
  standard
  control
  procedure
  guideline
}

/// NDI maturity level a specification targets (1 = initial ... 5 = optimized).
enum NdiMaturityLevel {
  level_1
  level_2
  level_3
  level_4
  level_5
}

/// A single NDI (National Data Index) specification / control requirement,
/// grouped under an NDI domain. Used by the NDI Compliance Hub registry.
model NdiSpecification {
  id                 String           @id @default(uuid())
  code               String           @unique
  domainId           String
  criterion          String?
  type               NdiSpecType      @default(standard)
  maturityLevel      NdiMaturityLevel @default(level_1)
  nameEn             String
  nameAr             String
  descriptionEn      String?
  descriptionAr      String?
  acceptanceCriteria String?
  reference          String?
  /// Optional accountable owner for this specification (drives evidence ownership/routing).
  ownerPersonId      String?
  isActive           Boolean          @default(true)
  sortOrder          Int              @default(0)
  deletedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  domain    NdiDomain     @relation(fields: [domainId], references: [id])
  owner     Person?       @relation("NdiSpecOwner", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  evidence  NdiEvidence[]

  @@index([domainId])
  @@index([type])
  @@index([maturityLevel])
  @@index([isActive])
  @@index([ownerPersonId])
  @@map("ndi_specifications")
}

/// Lifecycle states for a piece of NDI compliance evidence.
enum NdiEvidenceStatus {
  draft
  submitted
  under_review
  approved
  rejected
  expired
  revoked
}

/// A piece of evidence (an uploaded file) demonstrating compliance with an
/// NDI specification. Goes through a submit -> review lifecycle and can expire.
model NdiEvidence {
  id            String            @id @default(uuid())
  specId        String
  title         String
  descriptionEn String?
  status        NdiEvidenceStatus @default(draft)
  // Stored file metadata
  fileName      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  sha256        String
  // Lifecycle / review
  submittedBy   String
  submittedAt   DateTime?
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  expiryDate    DateTime?
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  spec NdiSpecification @relation(fields: [specId], references: [id], onDelete: Cascade)
  openDataAssessments OpenDataAssessment[] @relation("OpenDataAssessmentEvidence")
  openDataPublications OpenDataPublication[] @relation("OpenDataPublicationEvidence")
  mdmMatchCandidates MdmMatchCandidate[] @relation("MdmMatchEvidence")
  referenceDataVersions ReferenceDataVersion[] @relation("ReferenceVersionEvidence")
  metadataCertifications MetadataCertification[] @relation("MetadataCertificationEvidence")
  architectureReviews ArchitectureReview[] @relation("ArchitectureReviewEvidence")

  @@index([specId])
  @@index([status])
  @@index([expiryDate])
  @@map("ndi_evidence")
}

/// Data subjects (categories of individuals/entities the data is about).
model DataSubject {
  id          String    @id @default(uuid())
  code        String    @unique
  nameEn      String
  nameAr      String
  description String?
  isActive    Boolean        @default(true)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  assetLinks  AssetSubject[]

  @@map("data_subjects")
}

/// Business capabilities (hierarchical map of what the organization does).
model BusinessCapability {
  id          String               @id @default(uuid())
  code        String               @unique
  nameEn      String
  nameAr      String
  description String?
  parentId    String?
  parent      BusinessCapability?  @relation("CapabilityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    BusinessCapability[] @relation("CapabilityTree")
  assets      DataAsset[]
  isActive    Boolean              @default(true)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([parentId])
  @@map("business_capabilities")
}

/// Governed data assets (the core inventory of data the organization manages).
model DataAsset {
  id                String    @id @default(uuid())
  code              String    @unique
  nameEn            String
  nameAr            String
  description       String?
  /// Lifecycle status code (see StatusValue domain "lifecycle"): draft, active, deprecated, retired.
  lifecycleStatus   String    @default("draft")
  /// Ownership state for filtering: unassigned | assigned (full registry arrives in Sprint 5).
  ownerStatus       String    @default("unassigned")
  ownerName         String?
  domainId          String?
  orgUnitId         String?
  systemId          String?
  capabilityId      String?
  classificationId  String?
  domain            DataDomain?         @relation(fields: [domainId], references: [id], onDelete: SetNull)
  orgUnit           OrganizationUnit?   @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)
  system            SystemPlatform?     @relation(fields: [systemId], references: [id], onDelete: SetNull)
  capability        BusinessCapability? @relation(fields: [capabilityId], references: [id], onDelete: SetNull)
  classification    Classification?     @relation(fields: [classificationId], references: [id], onDelete: SetNull)
  subjects          AssetSubject[]
  outgoingRelations AssetRelationship[] @relation("AssetRelSource")
  incomingRelations AssetRelationship[] @relation("AssetRelTarget")
  workflowCases     WorkflowCase[]
  dataQualityIssues DataQualityIssue[]
  dqRules           DataQualityRule[]
  dqScores          DataQualityScore[]
  dqProfiles        DataQualityProfile[]
  accessReviewItems AccessReviewItem[]
  abacDecisions     AbacDecisionLog[]
  dlpIncidents      DlpIncident[]
  classificationRequests ClassificationChangeRequest[]
  openDataCandidates OpenDataCandidate[]
  foiRequests       FoiRequest[]
  privacyRopaRecords PrivacyRopaRecord[]
  privacyDpiaRecords PrivacyDpia[]
  privacyDsrRequests PrivacyDsrRequest[]
  privacyBreaches PrivacyBreach[]
  consentRecords PrivacyConsentRecord[]
  privacyRetentionRules PrivacyRetentionRule[]
  dataSharingRequests DataSharingRequest[]
  dataSharingAgreements DataSharingAgreement[]
  referenceDataVersions ReferenceDataVersion[]
  mdmMatchSourceCandidates MdmMatchCandidate[] @relation("MdmMatchSourceAsset")
  mdmMatchCandidateRecords MdmMatchCandidate[] @relation("MdmMatchCandidateAsset")
  metadataCertifications MetadataCertification[]
  architectureReviews ArchitectureReview[]
  businessGlossaryTerms BusinessGlossaryTerm[]
  businessLineageSourceMaps BusinessLineageMap[] @relation("BusinessLineageSourceAsset")
  businessLineageTargetMaps BusinessLineageMap[] @relation("BusinessLineageTargetAsset")
  dataAssetValuations DataAssetValuation[]
  dataUserSurveys DataUserSurvey[]
  assetLifecycleDecisions AssetLifecycleDecision[]
  businessImpactAssessments BusinessImpactAssessment[]
  dataValueKpis DataValueKpi[]
  externalCatalogId String?
  catalogSource     String?
  catalogSyncStatus DataAssetCatalogSyncStatus @default(not_synced)
  catalogTrustLevel IntegrationSourceTrust     @default(observed)
  catalogLastSyncedAt DateTime?
  catalogWritebackStatus IntegrationWritebackStatus?
  externalReferences IntegrationExternalReference[]
  integrationWritebacks IntegrationWritebackLog[]
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([domainId])
  @@index([orgUnitId])
  @@index([systemId])
  @@index([capabilityId])
  @@index([classificationId])
  @@index([lifecycleStatus])
  @@index([ownerStatus])
  @@index([externalCatalogId])
  @@index([catalogSource])
  @@index([catalogSyncStatus])
  @@map("data_assets")
}

/// Many-to-many mapping of data assets to the data subjects they describe.
model AssetSubject {
  assetId       String
  dataSubjectId String
  asset         DataAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  dataSubject   DataSubject @relation(fields: [dataSubjectId], references: [id], onDelete: Cascade)

  @@id([assetId, dataSubjectId])
  @@index([dataSubjectId])
  @@map("asset_subjects")
}

/// Directed relationship between two data assets (lineage / association).
model AssetRelationship {
  id            String    @id @default(uuid())
  sourceAssetId String
  targetAssetId String
  /// Relationship type code: derived_from, feeds, replicates, related_to.
  type          String
  description   String?
  createdAt     DateTime  @default(now())
  sourceAsset   DataAsset @relation("AssetRelSource", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  targetAsset   DataAsset @relation("AssetRelTarget", fields: [targetAssetId], references: [id], onDelete: Cascade)

  @@unique([sourceAssetId, targetAssetId, type])
  @@index([targetAssetId])
  @@map("asset_relationships")
}

/// Governance dimensions a stewardship assignment or rule can target.
enum AssignmentTargetType {
  asset
  domain
  capability
  subject
  org_unit
  system
}

/// Who is responsible (owner/steward) for a specific governed target.
model StewardshipAssignment {
  id            String               @id @default(uuid())
  targetType    AssignmentTargetType
  targetId      String
  roleTypeId    String
  personId      String
  isPrimary     Boolean              @default(true)
  effectiveDate DateTime             @default(now())
  expiryDate    DateTime?
  justification String?
  /// How this assignment was created: manual | rule | override.
  source        String               @default("manual")
  /// Approval state; only `approved` assignments are authoritative (set owner / clear exception).
  approvalStatus ApprovalStatus      @default(approved)
  reviewedBy    String?
  reviewedAt    DateTime?
  isActive      Boolean              @default(true)
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  roleType      RoleType             @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)
  person        Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  workflowCases WorkflowCase[]

  @@index([targetType, targetId])
  @@index([roleTypeId])
  @@index([personId])
  @@map("stewardship_assignments")
}

/// Rule that recommends an owner/steward for assets matching a governance dimension.
model AssignmentRule {
  id          String               @id @default(uuid())
  nameEn      String
  nameAr      String
  description String?
  /// Dimension the rule matches against (asset is not allowed: rules drive recommendations).
  scopeType   AssignmentTargetType
  refId       String
  roleTypeId  String
  personId    String
  isPrimary   Boolean              @default(true)
  /// Tiebreaker within the same scope level (lower wins).
  priority    Int                  @default(100)
  isActive    Boolean              @default(true)
  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  roleType    RoleType             @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)
  person      Person               @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([scopeType, refId])
  @@index([roleTypeId])
  @@map("assignment_rules")
}

/// Approval state of a stewardship assignment.
enum ApprovalStatus {
  draft
  pending
  approved
  rejected
}

/// Lifecycle states for a governance workflow case.
enum CaseStatus {
  draft
  submitted
  under_review
  awaiting_information
  decision_made
  approved
  rejected
  implemented
  closed
}

/// Lifecycle states for a workflow task.
enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

/// Decision recorded on a workflow task.
enum TaskDecision {
  approved
  rejected
}

/// A governance workflow case (a controlled piece of work, e.g. an assignment approval).
model WorkflowCase {
  id           String                 @id @default(uuid())
  code         String                 @unique
  title        String
  description  String?
  /// Case type: general | owner_assignment_approval | steward_assignment_approval.
  type         String                 @default("general")
  status       CaseStatus             @default(draft)
  templateId   String?
  assetId      String?
  assignmentId String?
  createdBy    String
  template     WorkflowTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  asset        DataAsset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignment   StewardshipAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  tasks        WorkflowTask[]
  events       WorkflowEvent[]
  dataQualityIssue DataQualityIssue?
  dlpIncident DlpIncident?
  classificationChangeRequest ClassificationChangeRequest?
  openDataApprovals OpenDataApproval[]
  foiRequest FoiRequest?
  foiAppeal FoiAppeal?
  privacyDpia PrivacyDpia?
  privacyDsrRequest PrivacyDsrRequest?
  privacyBreach PrivacyBreach?
  dataSharingRequest DataSharingRequest?
  metadataCertification MetadataCertification?
  architectureReview ArchitectureReview?
  businessGlossaryTerm BusinessGlossaryTerm?
  businessLineageMap BusinessLineageMap?
  assetLifecycleDecision AssetLifecycleDecision?
  businessImpactAssessment BusinessImpactAssessment?
  governanceNotifications GovernanceNotification[]
  governanceEscalations GovernanceEscalation[]
  complianceCalendarOccurrences ComplianceCalendarOccurrence[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([status])
  @@index([type])
  @@index([templateId])
  @@index([assetId])
  @@map("workflow_cases")
}

/// A unit of work inside a workflow case, assigned to a user account.
model WorkflowTask {
  id              String          @id @default(uuid())
  caseId          String
  title           String
  /// Task type: approval | review | information.
  type            String          @default("review")
  status          TaskStatus      @default(pending)
  assigneeUserId  String?
  assigneeRoleCode String?
  dueDate         DateTime?
  decision        TaskDecision?
  decisionComment String?
  completedAt     DateTime?
  case            WorkflowCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateStageId String?
  templateStage   WorkflowTemplateStage? @relation(fields: [templateStageId], references: [id], onDelete: SetNull)
  assignee        User?           @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  events          WorkflowEvent[]
  governanceNotifications GovernanceNotification[]
  governanceEscalations GovernanceEscalation[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([caseId])
  @@index([templateStageId])
  @@index([assigneeUserId])
  @@index([assigneeRoleCode])
  @@index([status])
  @@index([assigneeUserId, status, dueDate])
  @@index([assigneeRoleCode, status, dueDate])
  @@map("workflow_tasks")
}

/// Append-only timeline of events for a workflow case (and optionally a task).
model WorkflowEvent {
  id         String        @id @default(uuid())
  caseId     String
  taskId     String?
  actor      String
  action     String
  fromStatus String?
  toStatus   String?
  comment    String?
  createdAt  DateTime      @default(now())
  case       WorkflowCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  task       WorkflowTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@map("workflow_events")
}

/// Reusable workflow route definition. Templates make case types visible and
/// configurable without replacing the existing case/task engine.
model WorkflowTemplate {
  id             String                       @id @default(uuid())
  code           String                       @unique
  caseType       String
  nameEn         String
  nameAr         String
  description    String?
  trigger        String                       @default("manual")
  domainId       String?
  defaultSlaDays Int                          @default(5)
  bpmnXml        String?
  designerJson   Json?
  designerVersion Int                         @default(1)
  lastPublishedAt DateTime?
  lastPublishedBy String?
  isSystem       Boolean                      @default(false)
  isActive       Boolean                      @default(true)
  deletedAt      DateTime?
  createdBy      String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  domain         DataDomain?                  @relation(fields: [domainId], references: [id], onDelete: SetNull)
  stages         WorkflowTemplateStage[]
  transitions    WorkflowTemplateTransition[]
  cases          WorkflowCase[]
  versions       WorkflowTemplateVersion[]

  @@index([caseType])
  @@index([domainId])
  @@index([isActive])
  @@map("workflow_templates")
}

/// Versioned BPMN snapshots for workflow templates. Publishing creates an
/// immutable snapshot so administrators can trace how a route changed.
model WorkflowTemplateVersion {
  id             String           @id @default(uuid())
  templateId     String
  version        Int
  source         String           @default("designer")
  changeSummary  String?
  bpmnXml        String
  designerJson   Json?
  validationJson Json?
  createdBy      String
  createdAt      DateTime         @default(now())
  template       WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
  @@map("workflow_template_versions")
}

/// A visible node in a workflow route. Stages can create default tasks when a
/// case is opened from the template.
model WorkflowTemplateStage {
  id               String                       @id @default(uuid())
  templateId       String
  code             String
  nameEn           String
  nameAr           String
  description      String?
  kind             String                       @default("review")
  nodeType         String                       @default("user_task")
  taskType         String                       @default("review")
  assignmentStrategy String                     @default("role")
  assigneeRoleCode String?
  dueDays          Int                          @default(2)
  formSchemaJson   Json?
  slaConfigJson    Json?
  notificationRulesJson Json?
  evidenceRequirementsJson Json?
  automationConfigJson Json?
  gatewayConfigJson Json?
  parallelGroup    String?
  sortOrder        Int                          @default(0)
  isStart          Boolean                      @default(false)
  isDecision       Boolean                      @default(false)
  isFinal          Boolean                      @default(false)
  isActive         Boolean                      @default(true)
  template         WorkflowTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  outgoing         WorkflowTemplateTransition[] @relation("WorkflowTransitionFrom")
  incoming         WorkflowTemplateTransition[] @relation("WorkflowTransitionTo")
  tasks            WorkflowTask[]

  @@unique([templateId, code])
  @@index([templateId])
  @@index([sortOrder])
  @@map("workflow_template_stages")
}

/// Directed branch between route stages, including decision branches.
model WorkflowTemplateTransition {
  id          String                @id @default(uuid())
  templateId  String
  fromStageId String
  toStageId   String
  labelEn     String
  labelAr     String
  decision    String?
  conditionExpression String?
  conditionJson Json?
  sortOrder   Int                   @default(0)
  isHappyPath Boolean               @default(true)
  isActive    Boolean               @default(true)
  retiredAt   DateTime?
  retiredBy   String?
  template    WorkflowTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fromStage   WorkflowTemplateStage @relation("WorkflowTransitionFrom", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStage     WorkflowTemplateStage @relation("WorkflowTransitionTo", fields: [toStageId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([fromStageId])
  @@index([toStageId])
  @@index([isActive])
  @@map("workflow_template_transitions")
}

/// Append-only audit log foundation.
model AuditLog {
  id         String   @id @default(uuid())
  actor      String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  previousHash String?
  entryHash    String?
  chainVersion Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([entryHash])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Lifecycle states for role-based governance training assignments.
enum TrainingAssignmentStatus {
  assigned
  in_progress
  completed
  expired
  waived
}

enum TrainingTier {
  tier_1
  tier_2
  tier_3
  tier_4
}

enum CertificationLevel {
  cds
  sds
  mds
}

enum CertificationAttemptStatus {
  in_progress
  passed
  failed
  expired
  revoked
}

enum MentorshipStatus {
  planned
  active
  completed
  cancelled
}

/// Governance training courses and awareness modules.
model TrainingCourse {
  id              String                 @id @default(uuid())
  code            String                 @unique
  titleEn         String
  titleAr         String
  description     String?
  category        String                 @default("governance")
  tier            TrainingTier           @default(tier_1)
  deliveryMethod  String                 @default("self_paced")
  prerequisiteCourseId String?
  prerequisiteCourse TrainingCourse?      @relation("TrainingPrerequisite", fields: [prerequisiteCourseId], references: [id], onDelete: SetNull)
  dependentCourses TrainingCourse[]       @relation("TrainingPrerequisite")
  durationMinutes Int                    @default(30)
  validityMonths  Int?
  isActive        Boolean                @default(true)
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  requirements    TrainingRequirement[]
  assignments     TrainingAssignment[]

  @@index([category])
  @@index([tier])
  @@index([prerequisiteCourseId])
  @@index([isActive])
