  approvedAt        DateTime?
  createdBy         String
  updatedBy         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  asset             DataAsset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  workflowCase      WorkflowCase?           @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([status])
  @@index([disposalDueAt])
  @@map("asset_lifecycle_decisions")
}

model BusinessImpactAssessment {
