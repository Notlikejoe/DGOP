/// Operational data quality issue tracked through ownership, workflow, and audit.
model DataQualityIssue {
  id                  String                   @id @default(uuid())
  code                String                   @unique
  title               String
  description         String?
  severity            DataQualitySeverity      @default(medium)
  dimension           DataQualityDimension     @default(completeness)
  priority            DataQualityPriority      @default(P3)
  status              DataQualityIssueStatus   @default(open)
  source              String                   @default("manual")
  assetId             String?
  responsiblePersonId String?
  workflowCaseId      String?                  @unique
  detectedAt          DateTime                 @default(now())
  dueDate             DateTime?
  triageDueAt         DateTime?
  remediationDueAt    DateTime?
  validationDueAt     DateTime?
  escalatedAt         DateTime?
  resolutionSummary   String?
  closedAt            DateTime?
  createdBy           String
  deletedAt           DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  asset               DataAsset?               @relation(fields: [assetId], references: [id], onDelete: SetNull)
  responsiblePerson   Person?                  @relation(fields: [responsiblePersonId], references: [id], onDelete: SetNull)
  workflowCase        WorkflowCase?            @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)
