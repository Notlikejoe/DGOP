  @@map("integration_connectors")
}

model IntegrationJob {
  id            String               @id @default(uuid())
  code          String               @unique
  connectorId   String
  nameEn        String
  nameAr        String
  jobType       IntegrationJobType   @default(catalog_sync)
  status        IntegrationJobStatus @default(ready)
  syncMode      String               @default("manual")
  scheduleCron  String?
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdBy     String?
  isActive      Boolean              @default(true)
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  connector     IntegrationConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  importBatches IntegrationImportBatch[]

  @@index([connectorId])
  @@index([jobType])
  @@index([status])
  @@index([isActive])
  @@map("integration_jobs")
}

model IntegrationImportBatch {
  id                 String                 @id @default(uuid())
  code               String                 @unique
  connectorId        String
  jobId              String?
  sourceName         String?
  adapterType        IntegrationAdapterType @default(catalog_csv)
  status             IntegrationBatchStatus @default(running)
  startedAt          DateTime               @default(now())
  completedAt        DateTime?
  triggeredBy        String
  totalRows          Int                    @default(0)
  createdRows        Int                    @default(0)
  updatedRows        Int                    @default(0)
  unchangedRows      Int                    @default(0)
  errorRows          Int                    @default(0)
  warningRows        Int                    @default(0)
  reconciliationJson Json?
  mappingPreviewJson Json?
  connector          IntegrationConnector   @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  job                IntegrationJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  errors             IntegrationImportError[]
  writebackLogs      IntegrationWritebackLog[]

  @@index([connectorId])
  @@index([jobId])
  @@index([status])
  @@index([startedAt])
  @@map("integration_import_batches")
}

model IntegrationImportError {
  id         String                         @id @default(uuid())
  batchId    String
  rowNumber  Int
  externalId String?
  field      String?
  message    String
  severity   IntegrationImportErrorSeverity @default(error)
  rawRowJson  Json?
  createdAt  DateTime                       @default(now())
  batch      IntegrationImportBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([severity])
  @@map("integration_import_errors")
}

model IntegrationExternalReference {
  id          String                 @id @default(uuid())
  connectorId String
  externalId  String
  entityType  IntegrationEntityType  @default(data_asset)
  entityId    String?
  assetId     String?
  sourceTrust IntegrationSourceTrust @default(authoritative)
  syncStatus  DataAssetCatalogSyncStatus @default(synced)
  lastSeenAt  DateTime               @default(now())
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  connector   IntegrationConnector   @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  asset       DataAsset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([connectorId, externalId, entityType])
  @@index([assetId])
  @@index([entityType])
  @@index([syncStatus])
  @@map("integration_external_references")
}

model IntegrationWritebackLog {
  id          String                     @id @default(uuid())
  connectorId String
  assetId     String
  batchId     String?
  status      IntegrationWritebackStatus @default(simulated)
  simulated   Boolean                    @default(true)
  payloadJson Json
  resultJson  Json?
  message     String?
  actor       String
  createdAt   DateTime                   @default(now())
  connector   IntegrationConnector       @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  asset       DataAsset                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  batch       IntegrationImportBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([connectorId])
  @@index([assetId])
  @@index([status])
  @@index([createdAt])
  @@map("integration_writeback_logs")
}
