  sourceAsset     DataAsset?            @relation("BusinessLineageSourceAsset", fields: [sourceAssetId], references: [id], onDelete: SetNull)
  targetAsset     DataAsset?            @relation("BusinessLineageTargetAsset", fields: [targetAssetId], references: [id], onDelete: SetNull)
  domain          DataDomain?           @relation(fields: [domainId], references: [id], onDelete: SetNull)
  workflowCase    WorkflowCase?         @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)

  @@index([sourceAssetId])
  @@index([targetAssetId])
  @@index([domainId])
  @@index([status])
  @@map("business_lineage_maps")
}

model DataAssetValuation {
  id             String          @id @default(uuid())
  code           String          @unique
  assetId        String
  domainId       String?
  useCase        String
  valueDriver    String?
  annualValue    Float           @default(0)
  roiPercent     Int             @default(0)
  adoptionScore  Int             @default(0)
  surveyScore    Int             @default(0)
  status         DataValueStatus @default(measuring)
  ownerName      String?
  createdBy      String
  updatedBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  asset          DataAsset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  domain         DataDomain?     @relation(fields: [domainId], references: [id], onDelete: SetNull)
  surveys        DataUserSurvey[]

  @@index([assetId])
  @@index([domainId])
  @@index([status])
  @@map("data_asset_valuations")
}

model DataUserSurvey {
  id          String              @id @default(uuid())
  valuationId String?
  assetId     String?
  respondent  String?
  score       Int                 @default(0)
  feedback    String?
  createdBy   String
  createdAt   DateTime            @default(now())
  valuation   DataAssetValuation? @relation(fields: [valuationId], references: [id], onDelete: SetNull)
  asset       DataAsset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([valuationId])
  @@index([assetId])
  @@map("data_user_surveys")
}

model AssetLifecycleDecision {
