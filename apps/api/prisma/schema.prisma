  rcaRecords          DataQualityRcaRecord[]
  slaBreaches         DataQualitySlaBreach[]
  scores              DataQualityScore[]

  @@index([assetId])
  @@index([responsiblePersonId])
  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([dueDate])
  @@index([triageDueAt])
  @@index([remediationDueAt])
  @@map("data_quality_issues")
}

