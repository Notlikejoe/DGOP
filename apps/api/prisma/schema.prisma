  classificationSignal   OpenDataSignalStatus           @default(needs_review)
  dataQualitySignal      OpenDataSignalStatus           @default(needs_review)
  personalDataSignal     OpenDataSignalStatus           @default(needs_review)
  ownershipSignal        OpenDataSignalStatus           @default(needs_review)
  publicationValueSignal OpenDataSignalStatus           @default(needs_review)
