enum GovernanceNotificationSeverity {
  info
  success
  warning
  critical
}

enum GovernanceNotificationStatus {
  unread
  read
  archived
}

enum GovernanceEscalationLevel {
  domain_council
  data_stewardship_council
  data_governance_board
  executive_steering_committee
}

enum GovernanceEscalationStatus {
  open
  acknowledged
  resolved
  cancelled
}

enum ComplianceCalendarType {
  processing_activity_review
  cross_border_transfer_monitoring
  annual_dpia_review
  monthly_dq_scorecard_review
}

enum ComplianceCalendarStatus {
  active
  paused
  completed
  archived
}

model GovernanceNotification {
  id             String                         @id @default(uuid())
  dedupeKey      String?                        @unique
  title          String
  message        String
  severity       GovernanceNotificationSeverity @default(info)
  status         GovernanceNotificationStatus   @default(unread)
  sourceType     String?
  sourceId       String?
  targetRoleCode String?
  assigneeUserId String?
  workflowCaseId String?
  workflowTaskId String?
  emailTo        String?
  emailSentAt    DateTime?
  readAt         DateTime?
  createdBy      String
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  assignee       User?                          @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  workflowCase   WorkflowCase?                  @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)
  workflowTask   WorkflowTask?                  @relation(fields: [workflowTaskId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([targetRoleCode])
  @@index([assigneeUserId])
  @@index([workflowCaseId])
  @@index([workflowTaskId])
  @@map("governance_notifications")
}

model GovernanceEscalation {
  id             String                    @id @default(uuid())
  dedupeKey      String?                   @unique
  code           String                    @unique
  level          GovernanceEscalationLevel
  status         GovernanceEscalationStatus @default(open)
  sourceType     String
  sourceId       String
  reason         String
  penaltyPoints  Int                       @default(0)
  ownerRoleCode  String?
  dueAt          DateTime?
  escalatedAt    DateTime                  @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  workflowCaseId String?
  workflowTaskId String?
  createdBy      String
  updatedBy      String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  workflowCase   WorkflowCase?             @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)
  workflowTask   WorkflowTask?             @relation(fields: [workflowTaskId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([workflowCaseId])
  @@index([workflowTaskId])
  @@map("governance_escalations")
}

model ComplianceCalendarTemplate {
  id                     String                 @id @default(uuid())
  code                   String                 @unique
  title                  String
  type                   ComplianceCalendarType
  cadence                String
  ownerRoleCode          String?
  nextRunAt              DateTime
  lastRunAt              DateTime?
  defaultSlaBusinessDays Int                    @default(5)
  status                 ComplianceCalendarStatus @default(active)
  createdBy              String
  updatedBy              String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  occurrences            ComplianceCalendarOccurrence[]

  @@index([type])
  @@index([status])
  @@index([nextRunAt])
  @@map("compliance_calendar_templates")
}

model ComplianceCalendarOccurrence {
  id             String                   @id @default(uuid())
  templateId     String
  code           String                   @unique
  title          String
  status         ComplianceCalendarStatus @default(active)
  dueAt          DateTime
  completedAt    DateTime?
  workflowCaseId String?
  createdBy      String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  template       ComplianceCalendarTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workflowCase   WorkflowCase?            @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([status])
  @@index([dueAt])
  @@index([workflowCaseId])
  @@map("compliance_calendar_occurrences")
}

model KsaHoliday {
  id          String   @id @default(uuid())
  date        DateTime @unique
  nameEn      String
  nameAr      String?
  isRecurring Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isRecurring])
  @@map("ksa_holidays")
}
