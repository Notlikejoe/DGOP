enum DataQualityIssueStatus {
  open
  triaged
  in_progress
  resolved
  closed
  cancelled
}

enum DataQualitySeverity {
  low
  medium
  high
  critical
}

enum DataQualityDimension {
  completeness
  accuracy
  validity
  consistency
  timeliness
  uniqueness
}

enum DataQualityPriority {
  P1
  P2
  P3
  P4
}

enum DataQualityRuleStatus {
  draft
  in_review
  approved
  deployed
  retired
}

enum DataQualityRcaTemplate {
  five_whys
  fishbone
  process_map
  lineage_analysis
}

enum DataQualityScoreLevel {
  enterprise
  domain
  asset
  data_element
  rule
  issue
}

enum DataQualitySlaStage {
  triage
  remediation
  validation
  closure
}

enum DataQualitySlaStatus {
  active
  breached
  completed
  waived
}

/// Operational data quality issue tracked through ownership, workflow, and audit.
model DataQualityIssue {
  id                  String                   @id @default(uuid())
  code                String                   @unique
  title               String
  description         String?
  severity            DataQualitySeverity      @default(medium)
  dimension           DataQualityDimension     @default(completeness)
  priority            DataQualityPriority      @default(P3)
  status              DataQualityIssueStatus   @default(open)
  source              String                   @default("manual")
  assetId             String?
  responsiblePersonId String?
  workflowCaseId      String?                  @unique
  detectedAt          DateTime                 @default(now())
  dueDate             DateTime?
  triageDueAt         DateTime?
  remediationDueAt    DateTime?
  validationDueAt     DateTime?
  escalatedAt         DateTime?
  resolutionSummary   String?
  closedAt            DateTime?
  createdBy           String
  deletedAt           DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  asset               DataAsset?               @relation(fields: [assetId], references: [id], onDelete: SetNull)
  responsiblePerson   Person?                  @relation(fields: [responsiblePersonId], references: [id], onDelete: SetNull)
  workflowCase        WorkflowCase?            @relation(fields: [workflowCaseId], references: [id], onDelete: SetNull)
  evidence            DataQualityIssueEvidence[]
  rcaRecords          DataQualityRcaRecord[]
  slaBreaches         DataQualitySlaBreach[]
  scores              DataQualityScore[]

  @@index([assetId])
  @@index([responsiblePersonId])
  @@index([status])
  @@index([severity])
  @@index([priority])
  @@index([dueDate])
  @@index([triageDueAt])
  @@index([remediationDueAt])
  @@map("data_quality_issues")
}

/// Lightweight evidence/history trail for data quality issue actions.
model DataQualityIssueEvidence {
  id        String           @id @default(uuid())
  issueId   String
  action    String
  note      String?
  actor     String
  metadata  Json?
  createdAt DateTime         @default(now())
  issue     DataQualityIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@map("data_quality_issue_evidence")
}

model DataQualityRule {
  id                  String                @id @default(uuid())
  code                String                @unique
  nameEn              String
  nameAr              String
  description         String?
  dimension           DataQualityDimension  @default(completeness)
  status              DataQualityRuleStatus @default(draft)
  assetId             String?
  domainId            String?
  ownerPersonId       String?
  severity            DataQualitySeverity   @default(medium)
  thresholdExpression String?
  checkFrequency      String                @default("weekly")
  impactSummary       String?
  currentVersion      Int                   @default(1)
  approvedBy          String?
  approvedAt          DateTime?
  deployedAt          DateTime?
  retiredAt           DateTime?
  deletedAt           DateTime?
  createdBy           String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  asset               DataAsset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  domain              DataDomain?           @relation(fields: [domainId], references: [id], onDelete: SetNull)
  ownerPerson         Person?               @relation(fields: [ownerPersonId], references: [id], onDelete: SetNull)
  versions            DataQualityRuleVersion[]
  scores              DataQualityScore[]

  @@index([assetId])
  @@index([domainId])
  @@index([ownerPersonId])
  @@index([status])
  @@index([dimension])
  @@map("data_quality_rules")
}

model DataQualityRuleVersion {
  id             String                @id @default(uuid())
  ruleId         String
  version        Int
  status         DataQualityRuleStatus @default(draft)
  definitionJson Json?
  changeSummary  String?
  createdBy      String
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime              @default(now())
  rule           DataQualityRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, version])
  @@index([status])
  @@map("data_quality_rule_versions")
}

model DataQualityScore {
  id            String                @id @default(uuid())
  level         DataQualityScoreLevel
  refId         String?
  dimension     DataQualityDimension?
  score         Int
  totalChecks   Int                   @default(0)
  failedChecks  Int                   @default(0)
  measuredAt    DateTime              @default(now())
  source        String                @default("manual")
  assetId       String?
  domainId      String?
  ruleId        String?
  issueId       String?
  notes         String?
  asset         DataAsset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  domain        DataDomain?           @relation(fields: [domainId], references: [id], onDelete: SetNull)
  rule          DataQualityRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  issue         DataQualityIssue?     @relation(fields: [issueId], references: [id], onDelete: SetNull)
  openDataCandidates OpenDataCandidate[]
  createdAt     DateTime              @default(now())

  @@index([level, refId])
  @@index([assetId])
  @@index([domainId])
  @@index([ruleId])
  @@index([issueId])
  @@index([dimension])
  @@index([measuredAt])
  @@map("data_quality_scores")
}

enum OpenDataCandidateStatus {
  draft
  assessment
  under_review
  approved
  published
  rejected
  retired
}

enum OpenDataPublicationFrequency {
  one_time
  daily
  weekly
  monthly
  quarterly
  semiannual
  annual
  on_demand
}

enum OpenDataPublicationFormat {
  csv
  json
  xlsx
  api
  geojson
  pdf
  other
}

enum OpenDataSignalStatus {
  ready
  needs_review
  blocked
}

enum OpenDataPersonalDataAssessment {
  none
  aggregated
  personal_data
  sensitive_personal_data
  unknown
}

enum OpenDataAssessmentStatus {
  draft
  completed
}

enum OpenDataApprovalDecision {
