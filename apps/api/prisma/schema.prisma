  odiaoReviewerPerson    Person?                        @relation("OpenDataReviewer", fields: [odiaoReviewerPersonId], references: [id], onDelete: SetNull)
  assessments            OpenDataAssessment[]
  approvals              OpenDataApproval[]
  publications           OpenDataPublication[]
  reviews                OpenDataReview[]
  usageMetrics           OpenDataUsageMetric[]

  @@index([assetId])
  @@index([status])
  @@index([ownerPersonId])
  @@index([stewardPersonId])
  @@index([odiaoReviewerPersonId])
  @@index([classificationId])
  @@index([dqScoreId])
  @@index([nextReviewAt])
  @@index([eligibilityScore])
  @@map("open_data_candidates")
}

model OpenDataAssessment {
